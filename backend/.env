# Bitaxe device IPs on your local network
# Add one per miner, comma separated
MINER_IPS=192.168.1.100,192.168.1.101,192.168.1.102

# How often to poll miners (seconds)
POLL_INTERVAL=30

# Server port
PORT=3001

# Bitcoin block reward (update after each halving)
BLOCK_REWARD_BTC=3.125

# Current BTC price in USD (or hook up a live API later)
BTC_PRICE_USD=96000

# Discord webhook URL (optional — leave blank to skip)
DISCORD_WEBHOOK_URL=

# Telegram bot token + chat ID (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
